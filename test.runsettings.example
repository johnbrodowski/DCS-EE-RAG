<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Set the environment variables for integration tests -->
    <EnvironmentVariables>
      <!-- Copy this file to 'test.runsettings' to configure integration tests. -->
      <!-- If these are omitted or missing, tests fall back to RAGConfiguration defaults: -->
      <!--   all-MiniLM-L6-v2-ONNX/model.onnx  (relative to build output) -->
      <!--   all-MiniLM-L6-v2-ONNX/vocab.txt    (relative to build output) -->
      <!-- Override only if your model lives elsewhere: -->

      <!-- <BERT_MODEL_PATH>C:\path\to\your\model.onnx</BERT_MODEL_PATH> -->
      <!-- <BERT_VOCAB_PATH>C:\path\to\your\vocab.txt</BERT_VOCAB_PATH> -->
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
